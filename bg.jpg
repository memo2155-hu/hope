body{
  margin:0;
  font-family:Arial;
  color:#e5e7eb;

  background-image:url("bg.jpg");
  background-size:cover;
  background-position:center;
  background-attachment:fixed;
}

/* overlay عشان الكلام يبان */
body::before{
  content:"";
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.4);
  z-index:-1;
}
